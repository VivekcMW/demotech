{
  "name": "@aarogya/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "compile": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile=aarogya-server"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@hono/zod-validator": "^0.4.0",
    "@sentry/node": "^10.58.0",
    "@sentry/profiling-node": "^10.58.0",
    "bcryptjs": "^2.4.3",
    "crypto-js": "^4.2.0",
    "drizzle-orm": "^0.40.0",
    "fhirpath": "^3.0.0",
    "node-hl7": "^2.5.0",
    "hono": "^4.7.0",
    "hono-rate-limiter": "^0.5.3",
    "jsonwebtoken": "^9.0.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
